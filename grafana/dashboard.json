{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "InfluxDB 3 — SQL mode",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__elements": {},
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "13.1.0"
    },
    {
      "type": "datasource",
      "id": "influxdb",
      "name": "InfluxDB",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "bargauge",
      "name": "Bar gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": false,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Weather station — temperature, humidity, wind, precipitation, pressure, solar radiation, air quality, ČHMÚ warnings",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Current Status",
      "type": "row"
    },

    {
      "type": "stat",
      "id": 2,
      "title": "Outdoor Temperature",
      "description": "Current air temperature measured by the station",
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 1,
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#5794F2", "value": null },
              { "color": "#73BF69", "value": 10 },
              { "color": "#FADE2A", "value": 20 },
              { "color": "#FF9830", "value": 28 },
              { "color": "#F2495C", "value": 35 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "rawSql": "SELECT time, meteo_temperature_celsius AS \"Temperature\"\nFROM meteo\nWHERE $__timeFilter(time) AND source = 'station'\nORDER BY time",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        }
      ]
    },

    {
      "type": "stat",
      "id": 3,
      "title": "Feels Like Temperature",
      "description": "Heat index (>27 °C, RH>40 %) or wind chill (≤10 °C, wind>4.8 km/h), otherwise actual temperature",
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 1,
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#5794F2", "value": null },
              { "color": "#73BF69", "value": 10 },
              { "color": "#FADE2A", "value": 20 },
              { "color": "#FF9830", "value": 28 },
              { "color": "#F2495C", "value": 35 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "rawSql": "SELECT time, meteo_feels_like_celsius AS \"Feels Like\"\nFROM meteo\nWHERE $__timeFilter(time) AND source = 'station'\nORDER BY time",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        }
      ]
    },

    {
      "type": "stat",
      "id": 4,
      "title": "Indoor Temperature",
      "description": "Temperature measured by the indoor sensor",
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 1,
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#5794F2", "value": null },
              { "color": "#73BF69", "value": 15 },
              { "color": "#FADE2A", "value": 22 },
              { "color": "#FF9830", "value": 26 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "rawSql": "SELECT time, meteo_indoor_temperature_celsius AS \"Indoors\"\nFROM meteo\nWHERE $__timeFilter(time) AND source = 'station'\nORDER BY time",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        }
      ]
    },

    {
      "type": "stat",
      "id": 5,
      "title": "Air Humidity",
      "description": "Relative humidity of outdoor air",
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 0,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FF9830", "value": null },
              { "color": "#FADE2A", "value": 30 },
              { "color": "#73BF69", "value": 45 },
              { "color": "#FADE2A", "value": 70 },
              { "color": "#5794F2", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "rawSql": "SELECT time, meteo_humidity_percent AS \"Humidity\"\nFROM meteo\nWHERE $__timeFilter(time) AND source = 'station'\nORDER BY time",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        }
      ]
    },

    {
      "type": "stat",
      "id": 6,
      "title": "Air Pressure",
      "description": "Atmospheric pressure. Falling pressure signals worsening weather, rising pressure signals improvement.",
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 1,
          "unit": "pressurehpa",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#F2495C", "value": null },
              { "color": "#FF9830", "value": 975 },
              { "color": "#FADE2A", "value": 995 },
              { "color": "#73BF69", "value": 1013 },
              { "color": "#5794F2", "value": 1025 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "rawSql": "SELECT time, meteo_pressure_hpa AS \"Pressure\"\nFROM meteo\nWHERE $__timeFilter(time) AND source = 'station'\nORDER BY time",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        }
      ]
    },

    {
      "type": "stat",
      "id": 7,
      "title": "Wind / Gust",
      "description": "Current wind speed and maximum gust",
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "vertical",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 1,
          "unit": "velocityms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "rawSql": "SELECT time, meteo_wind_speed_ms AS \"Speed\"\nFROM meteo\nWHERE $__timeFilter(time) AND source = 'station'\nORDER BY time",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "rawSql": "SELECT time, meteo_wind_gust_ms AS \"Gust\"\nFROM meteo\nWHERE $__timeFilter(time) AND source = 'station'\nORDER BY time",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "B"
        }
      ]
    },

    {
      "type": "stat",
      "id": 8,
      "title": "Precipitation Today",
      "description": "Total precipitation since midnight (daily station accumulation)",
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 1,
          "unit": "lengthmm",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#5794F2", "value": 1 },
              { "color": "#1F60C4", "value": 15 },
              { "color": "#8F3BB8", "value": 40 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "rawSql": "SELECT time, meteo_rain_daily_mm AS \"Rain Today\"\nFROM meteo\nWHERE $__timeFilter(time) AND source = 'station'\nORDER BY time",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        }
      ]
    },

    {
      "type": "stat",
      "id": 9,
      "title": "UV Index",
      "description": "Ultraviolet index. 0–2 low, 3–5 moderate, 6–7 high, 8–10 very high, 11+ extreme",
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 0,
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#FADE2A", "value": 3 },
              { "color": "#FF9830", "value": 6 },
              { "color": "#F2495C", "value": 8 },
              { "color": "#8F3BB8", "value": 11 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "rawSql": "SELECT time, meteo_uv_index AS \"UV Index\"\nFROM meteo\nWHERE $__timeFilter(time) AND source = 'station'\nORDER BY time",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "Temperature",
      "type": "row"
    },

    {
      "type": "timeseries",
      "id": 11,
      "title": "Temperatures",
      "description": "Outdoor temperature, feels-like temperature, indoor temperature, dew point, wet-bulb temperature and Open-Meteo forecast",
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 6 },
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "min", "max", "mean"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "celsius",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Feels Like" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [6, 4] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Dew Point" },
            "properties": [
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Forecast" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [8, 4] } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "fixedColor": "gray", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Wet Bulb" },
            "properties": [
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "rawSql": "SELECT\n  $__dateBin(time) AS time,\n  AVG(meteo_temperature_celsius) AS \"Outdoor\",\n  AVG(meteo_feels_like_celsius) AS \"Feels Like\",\n  AVG(meteo_indoor_temperature_celsius) AS \"Indoor\",\n  AVG(meteo_dew_point_celsius) AS \"Dew Point\",\n  AVG(meteo_wet_bulb_temperature_celsius) AS \"Wet Bulb\",\n  AVG(meteo_forecast_temperature_celsius) AS \"Forecast\"\nFROM meteo\nWHERE $__timeFilter(time) AND source = 'station'\nGROUP BY 1\nORDER BY 1",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 12,
      "title": "Wind",
      "type": "row"
    },

    {
      "type": "timeseries",
      "id": 13,
      "title": "Wind Speed and Gusts",
      "description": "Average wind speed and maximum gusts in m/s",
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 18, "x": 0, "y": 16 },
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "max", "mean"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "velocityms",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Gust" },
            "properties": [
              { "id": "custom.fillOpacity", "value": 20 },
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Speed" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "rawSql": "SELECT\n  $__dateBin(time) AS time,\n  AVG(meteo_wind_speed_ms) AS \"Speed\",\n  MAX(meteo_wind_gust_ms) AS \"Gust\"\nFROM meteo\nWHERE $__timeFilter(time) AND source = 'station'\nGROUP BY 1\nORDER BY 1",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        }
      ]
    },

    {
      "type": "stat",
      "id": 14,
      "title": "Wind Direction",
      "description": "Current wind direction in degrees and cardinal direction",
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "text" },
          "decimals": 0,
          "unit": "degree",
          "mappings": [
            { "type": "range", "options": { "from": 0, "to": 22.5, "result": { "text": "N ↑", "index": 0 } } },
            { "type": "range", "options": { "from": 22.5, "to": 67.5, "result": { "text": "NE ↗", "index": 1 } } },
            { "type": "range", "options": { "from": 67.5, "to": 112.5, "result": { "text": "E →", "index": 2 } } },
            { "type": "range", "options": { "from": 112.5, "to": 157.5, "result": { "text": "SE ↘", "index": 3 } } },
            { "type": "range", "options": { "from": 157.5, "to": 202.5, "result": { "text": "S ↓", "index": 4 } } },
            { "type": "range", "options": { "from": 202.5, "to": 247.5, "result": { "text": "SW ↙", "index": 5 } } },
            { "type": "range", "options": { "from": 247.5, "to": 292.5, "result": { "text": "W ←", "index": 6 } } },
            { "type": "range", "options": { "from": 292.5, "to": 337.5, "result": { "text": "NW ↖", "index": 7 } } },
            { "type": "range", "options": { "from": 337.5, "to": 360, "result": { "text": "N ↑", "index": 8 } } }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "rawSql": "SELECT time, meteo_wind_direction_degrees AS \"Direction\"\nFROM meteo\nWHERE $__timeFilter(time) AND source = 'station'\nORDER BY time",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 15,
      "title": "Precipitation and Humidity",
      "type": "row"
    },

    {
      "type": "timeseries",
      "id": 16,
      "title": "Precipitation",
      "description": "Daily precipitation accumulation and precipitation intensity in the given interval",
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#5794F2" },
          "unit": "lengthmm",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 30,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Intensity" },
            "properties": [
              {
                "id": "custom.drawStyle",
                "value": "bars"
              },
              { "id": "custom.fillOpacity", "value": 80 },
              { "id": "color", "value": { "fixedColor": "#1F60C4", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 0 }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "rawSql": "SELECT\n  $__dateBin(time) AS time,\n  MAX(meteo_rain_daily_mm) AS \"Total Today\",\n  SUM(meteo_rain_mm) AS \"Intensity\"\nFROM meteo\nWHERE $__timeFilter(time) AND source = 'station'\nGROUP BY 1\nORDER BY 1",
          "rawQuery": true,
          "resultFormat": "time_series",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "id": 17,
      "title": "Air Humidity",
