{% set default_image_repository = ('ghcr.io/' ~ lookup('env', 'GITHUB_REPOSITORY')) if lookup('env', 'GITHUB_REPOSITORY') else 'meteo-server' %}
{% set image_repository = lookup('env', 'METEO_SERVER_IMAGE_REPOSITORY') | default(lookup('env', 'CI_REGISTRY_IMAGE') | default(default_image_repository, true), true) %}
{% set image_tag_source = lookup('env', 'METEO_SERVER_IMAGE_TAG') | default(lookup('env', 'CI_COMMIT_REF_SLUG') | default(lookup('env', 'GITHUB_REF_NAME') | default('master', true), true), true) %}
{% set image_tag = image_tag_source | lower | regex_replace('[^a-z0-9_.-]+', '-') | regex_replace('^-+|-+$', '') %}
{% set rendered_image = lookup('env', 'METEO_SERVER_IMAGE') | default(image_repository ~ ':' ~ (image_tag or 'master'), true) %}
METEO_SERVER_IMAGE={{ rendered_image | to_json }}
METEO_SERVER_PORT={{ lookup('env', 'METEO_SERVER_PORT') | default('9996', true) | to_json }}

STATION_ID={{ lookup('env', 'METEO_STATION_ID') | to_json }}
STATION_PASSWORD={{ lookup('env', 'METEO_STATION_PASSWORD') | to_json }}
LAT={{ lookup('env', 'METEO_LAT') | to_json }}
LON={{ lookup('env', 'METEO_LON') | to_json }}

INFLUXDB_ADMIN_TOKEN={{ lookup('env', 'INFLUXDB_ADMIN_TOKEN') | to_json }}
INFLUXDB_IMAGE={{ lookup('env', 'INFLUXDB_IMAGE') | default('influxdb:3.9.2-core', true) | to_json }}
INFLUXDB_URL={{ lookup('env', 'INFLUXDB_URL') | default('http://meteo-db:8181', true) | to_json }}
INFLUXDB_DATABASE={{ lookup('env', 'INFLUXDB_DATABASE') | default('meteo', true) | to_json }}
INFLUXDB_PORT={{ lookup('env', 'INFLUXDB_PORT') | default('8181', true) | to_json }}
INFLUXDB_DATA_DIR={{ lookup('env', 'INFLUXDB_DATA_DIR') | default('./data', true) | to_json }}
INFLUXDB_UID={{ lookup('env', 'INFLUXDB_UID') | default('1000', true) | to_json }}
INFLUXDB_GID={{ lookup('env', 'INFLUXDB_GID') | default('1000', true) | to_json }}
INFLUXDB_NODE_IDENTIFIER_PREFIX={{ lookup('env', 'INFLUXDB_NODE_IDENTIFIER_PREFIX') | default('meteo', true) | to_json }}

OPEN_METEO_FORECAST_URL={{ lookup('env', 'OPEN_METEO_FORECAST_URL') | default('https://api.open-meteo.com/v1/forecast', true) | to_json }}
OPEN_METEO_AIR_QUALITY_URL={{ lookup('env', 'OPEN_METEO_AIR_QUALITY_URL') | default('https://air-quality-api.open-meteo.com/v1/air-quality', true) | to_json }}
CHMI_WARNINGS_URL={{ lookup('env', 'CHMI_WARNINGS_URL') | default('https://feeds.meteoalarm.org/feeds/meteoalarm-legacy-atom-czechia', true) | to_json }}
